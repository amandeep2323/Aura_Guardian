{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "firebase:rules": "firebase deploy --only database",
    "firebase:functions": "npm --prefix functions install && firebase deploy --only functions",
    "mobile:wrap": "node scripts/wrap-mobile.mjs",
